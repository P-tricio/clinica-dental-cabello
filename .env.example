# EmailJS Configuration
# Get these from https://www.emailjs.com/docs/rest-api/send-form/
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
# Chatbot: templates para solicitud de cita y contacto general
VITE_EMAILJS_TEMPLATE_ID_CITA=your_cita_template_id_here
VITE_EMAILJS_TEMPLATE_ID_CONTACTO=your_contacto_template_id_here

# OpenAI — SOLO server-side (Vercel). NUNCA usar prefijo VITE_ aquí.
# Añadir en Vercel Dashboard → Settings → Environment Variables
OPENAI_API_KEY=sk-your_openai_key_here

# Optional: Analytics
VITE_GA_MEASUREMENT_ID=your_google_analytics_id_here

# Environment
VITE_APP_NAME=Cabello Clínica Dental
VITE_APP_URL=https://clinicadentalcabello.es
